# App
NODE_ENV=development
HOST=0.0.0.0
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

# MongoDB Atlas is required so accounts and uploads are durable.
MONGODB_URI=
ALLOW_MEMORY_STORAGE=false

# Use long random values in production. Render can generate these automatically.
JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_SECRET=
OTP_TTL_MINUTES=10

# Human-behaviour team login. Generate the hash locally with:
# node -e "import('bcryptjs').then(({default:b})=>b.hash(process.argv[1],12).then(console.log))" "your-password"
ANALYTICS_TEAM_EMAIL=
ANALYTICS_TEAM_PASSWORD_HASH=

# Optional AWS verification. Username signup works without AWS.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
AWS_SNS_ORIGINATION_NUMBER=

# Media safeguards
MAX_UPLOAD_MB=250
MAX_FILES_PER_POST=20
