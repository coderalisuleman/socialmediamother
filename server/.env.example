# MongoDB Atlas is required. The root .env is loaded automatically.
NODE_ENV=development
HOST=0.0.0.0
PORT=5000
MONGODB_URI=
ALLOW_MEMORY_STORAGE=false
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

# Required in production. Use a long random value (32+ bytes).
JWT_SECRET=
JWT_EXPIRES_IN=7d
OTP_SECRET=
OTP_TTL_MINUTES=10

# Leave blank locally to receive devOtp in the OTP request response.
# In production, the appropriate AWS settings are required for email/phone OTP.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
AWS_SNS_ORIGINATION_NUMBER=

MAX_UPLOAD_MB=250
MAX_FILES_PER_POST=20
